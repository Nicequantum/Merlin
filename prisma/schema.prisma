generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Dealership {
  id           String        @id @default(cuid())
  name         String
  createdAt    DateTime      @default(now())
  technicians  Technician[]
  repairOrders RepairOrder[]
}

model Technician {
  id             String        @id @default(cuid())
  email          String        @unique
  name           String
  passwordHash   String
  role           String        @default("technician")
  dealershipId   String
  dealership     Dealership    @relation(fields: [dealershipId], references: [id])
  consentAt      DateTime?
  consentVersion String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  repairOrders   RepairOrder[]
}

model RepairOrder {
  id                    String       @id @default(cuid())
  roNumber              String
  technicianId          String
  technician            Technician   @relation(fields: [technicianId], references: [id])
  dealershipId          String
  dealership            Dealership   @relation(fields: [dealershipId], references: [id])
  vin                   String       @default("")
  year                  String       @default("")
  make                  String       @default("")
  model                 String       @default("")
  engine                String       @default("")
  mileageIn             String       @default("")
  mileageOut            String       @default("")
  customerNameEncrypted String       @default("")
  complaints            String       @default("[]")
  xentryOcrTexts        String       @default("[]")
  xentryImages          String       @default("[]")
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  repairLines           RepairLine[]

  @@index([technicianId])
  @@index([dealershipId])
  @@index([roNumber])
}

model RepairLine {
  id              String      @id @default(cuid())
  repairOrderId   String
  repairOrder     RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  lineNumber      Int
  description     String
  customerConcern String      @default("")
  technicianNotes String      @default("")
  xentryImages    String      @default("[]")
  xentryOcrTexts  String      @default("[]")
  extractedData   String      @default("{}")
  warrantyStory   String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([repairOrderId])
}