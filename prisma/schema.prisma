generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Dealership {
  id           String        @id @default(cuid())
  name         String
  createdAt    DateTime      @default(now())
  technicians  Technician[]
  repairOrders RepairOrder[]
  auditLogs    AuditLog[]
}

model Technician {
  id             String        @id @default(cuid())
  email          String        @unique
  name           String
  passwordHash   String
  role           String        @default("technician")
  isActive       Boolean       @default(true)
  dealershipId   String
  dealership     Dealership    @relation(fields: [dealershipId], references: [id])
  consentAt      DateTime?
  consentVersion String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  repairOrders   RepairOrder[]
  auditLogs      AuditLog[]

  @@index([dealershipId])
  @@index([isActive])
}

model RepairOrder {
  id                    String       @id @default(cuid())
  roNumber              String
  technicianId          String
  technician            Technician   @relation(fields: [technicianId], references: [id])
  dealershipId          String
  dealership            Dealership   @relation(fields: [dealershipId], references: [id])
  vin                   String       @default("")
  year                  String       @default("")
  make                  String       @default("")
  model                 String       @default("")
  engine                String       @default("")
  mileageIn             String       @default("")
  mileageOut            String       @default("")
  customerNameEncrypted String       @default("")
  complaints            String       @default("[]")
  xentryOcrTexts        String       @default("[]")
  xentryImageUrls       String       @default("[]")
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  repairLines           RepairLine[]

  @@index([technicianId])
  @@index([dealershipId])
  @@index([roNumber])
}

model RepairLine {
  id               String      @id @default(cuid())
  repairOrderId    String
  repairOrder      RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  lineNumber       Int
  description      String
  customerConcern  String      @default("")
  technicianNotes  String      @default("")
  xentryImageUrls  String      @default("[]")
  xentryOcrTexts   String      @default("[]")
  extractedData    String      @default("{}")
  warrantyStory    String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([repairOrderId])
}

model AuditLog {
  id           String      @id @default(cuid())
  action       String
  entityType   String?
  entityId     String?
  technicianId String?
  technician   Technician? @relation(fields: [technicianId], references: [id], onDelete: SetNull)
  dealershipId String
  dealership   Dealership  @relation(fields: [dealershipId], references: [id])
  metadata     String      @default("{}")
  ipAddress    String?
  createdAt    DateTime    @default(now())

  @@index([dealershipId])
  @@index([technicianId])
  @@index([action])
  @@index([createdAt])
}